<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital@0;1&family=Dancing+Script:wght@400&family=Montserrat:wght@300;400;600&display=swap');
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #f5f4f2; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: 'Montserrat', sans-serif; }
  .signature-wrapper { background: white; padding: 40px; }
  .signature { display: flex; align-items: center; width: 660px; background: white; }
  .left-block { display: flex; flex-direction: column; align-items: center; gap: 6px; padding-right: 28px; min-width: 160px; }
  .name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; color: #1B365D; text-align: center; line-height: 1.3; }
  .title-script { font-family: 'Dancing Script', cursive; font-size: 15px; color: #E07A5F; font-weight: 400; margin-top: -2px; }
  .avatar { width: 82px; height: 82px; border-radius: 50%; overflow: hidden; border: 2.5px solid #E07A5F; flex-shrink: 0; }
  .avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .divider { width: 1px; height: 120px; background: #1B365D; opacity: 0.25; flex-shrink: 0; }
  .right-block { padding-left: 28px; display: flex; flex-direction: column; gap: 10px; }
  .brand-name { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 400; color: #1B365D; letter-spacing: 0.02em; line-height: 1; }
  .brand-name span { font-style: italic; color: #E07A5F; }
  .brand-tagline { font-family: 'Montserrat', sans-serif; font-size: 8.5px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #B8B0A4; margin-top: 4px; }
  .contact-list { display: flex; flex-direction: column; gap: 5px; list-style: none; }
  .contact-list li { display: flex; align-items: center; gap: 8px; font-size: 11.5px; color: #333; font-weight: 300; }
  .contact-list .icon { width: 18px; height: 18px; background: #1B365D; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .contact-list .icon svg { width: 9px; height: 9px; fill: white; }
  .contact-list a { color: #333; text-decoration: none; font-weight: 300; }
  .contact-list .website a, .contact-list .linkedin a { font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; font-size: 10px; color: #1B365D; }
  .copy-btn { margin-top: 16px; display: block; width: 660px; padding: 10px; background: #1B365D; color: white; border: none; font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; text-align: center; }
  .copy-btn:hover { background: #E07A5F; }
  .export-note { margin-top: 8px; font-size: 11px; color: #999; font-family: 'Montserrat', sans-serif; text-align: center; font-style: italic; }
</style>
</head>
<body>
<div style="display:flex;flex-direction:column;align-items:center;">
  <div id="sig" class="signature-wrapper">
    <div class="signature">
      <div class="left-block">
        <div class="name">Marjorie<br>Mathieu</div>
        <div class="title-script">fondatrice</div>
        <div class="avatar">
          <img src="data:image/jpeg;base64," alt="Marjorie Mathieu">
        </div>
      </div>
      <div class="divider"></div>
      <div class="right-block">
        <div class="brand-block">
          <div class="brand-name">Équilibre <span>Performance</span></div>
          <div class="brand-tagline">Culture d'entreprise · Rituels opérationnels</div>
        </div>
        <ul class="contact-list">
          <li>
            <span class="icon"><svg viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C9.61 21 3 14.39 3 6a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.26.2 2.47.57 3.58a1 1 0 0 1-.25 1.01l-2.2 2.2z"/></svg></span>
            <a href="tel:+32477091803">+32 477 09 18 03</a>
          </li>
          <li>
            <span class="icon"><svg viewBox="0 0 24 24"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg></span>
            <a href="mailto:hello@marjoriemathieu.be">hello@marjoriemathieu.be</a>
          </li>
          <li class="website">
            <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="10"/><ellipse cx="12" cy="12" rx="4" ry="10"/><line x1="2" y1="12" x2="22" y2="12"/></svg></span>
            <a href="https://marjoriemathieu.github.io/equipes-qui-restent/">EQUIPES-QUI-RESTENT.BE</a>
          </li>
          <li class="linkedin">
            <span class="icon"><svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg></span>
            <a href="https://www.linkedin.com/in/equipes-qui-restent/">LINKEDIN / EQUIPES-QUI-RESTENT</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <button class="copy-btn" onclick="copyHTML()">📋 Copier le code HTML pour Infomaniak / Gmail / Outlook</button>
  <p class="export-note">Voir les instructions Infomaniak ci-dessous</p>
</div>
<script>
function copyHTML() {
  const sig = document.getElementById('sig').innerHTML;
  navigator.clipboard.writeText(sig).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.textContent = '✅ Code copié !';
    setTimeout(() => btn.textContent = '📋 Copier le code HTML pour Infomaniak / Gmail / Outlook', 2500);
  });
}
</script>
</body>
</html>
